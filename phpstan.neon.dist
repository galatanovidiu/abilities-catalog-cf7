# https://phpstan.org/config-reference

parameters:
	# Rules
	treatPhpDocTypesAsCertain: false
	inferPrivatePropertyTypeFromConstructor: true
	checkExplicitMixedMissingReturn: true
	checkFunctionNameCase: true
	checkInternalClassCaseSensitivity: true
	checkTooWideReturnTypesInProtectedAndPublicMethods: true
	polluteScopeWithAlwaysIterableForeach: false
	polluteScopeWithLoopInitialAssignments: false
	reportAlwaysTrueInLastCondition: true
	reportStaticMethodSignatures: true
	reportWrongPhpDocTypeInVarTag: true

	# Configuration
	level: 8
	phpVersion:
		min: 80100
		max: 80500
	bootstrapFiles:
		- abilities-catalog-cf7.php
	paths:
		- abilities-catalog-cf7.php
		- includes/
	excludePaths:
		analyse:
			- vendor/ (?)
		analyseAndScan:
			- node_modules (?)

	# Do not fail when an ignore pattern matches nothing (keeps the shared
	# ignore list portable as the codebase changes).
	reportUnmatchedIgnoredErrors: false

	ignoreErrors:
		- # TODO: These are too noisy, we'll restore them in the future.
			identifier: missingType.iterableValue

		# Contact Form 7 is the runtime dependency, absent from the analysis path and
		# from the WordPress stubs. All CF7 symbol access is confined to this one
		# facade, so its unknown-symbol errors are ignored here and nowhere else.
		-
			identifier: class.notFound
			path: includes/Support/Cf7Plugin.php
		-
			identifier: function.notFound
			message: '#Function wpcf7_contact_form not found\.#'
			path: includes/Support/Cf7Plugin.php
